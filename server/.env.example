# MongoDB Connection String (use MongoDB Atlas free cluster)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/friends_bd?retryWrites=true&w=majority

# Server Port
PORT=5000

# CORS Origin — comma-separated list of allowed frontend URLs
CORS_ORIGIN=https://your-app.vercel.app

# JWT Secret — generate a strong random string
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret

# Gemini AI API Key (server-side, NOT exposed to clients)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
